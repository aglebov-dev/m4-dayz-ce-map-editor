# виртуальное окружение
.venv/

# кэши Python
__pycache__/
*.pyc

# состояние приложения (создаётся само)
settings.json

# артефакты смоук-теста
tools/smoke_*.png

# локальные данные сервера/подложки
DATA_SAMPLE_SERVER/

# служебные данные приложения (подложки, конфиги проектов, снапшоты)
appdata/

# сборка (pyside6-deploy / Nuitka)
/dist/
/src/deployment/
/src/*.build/
/src/*.dist/
/src/*.onefile-build/
/src/app.exe
# спека, которую генерит CI из pysidedeploy.spec (абсолютные пути -> пути раннера)
/src/pysidedeploy.ci.spec

# bundled-ассеты: тайлы подложки и датасеты зданий приложение извлекает из файлов игры
# само (в appdata/), в git их не держим — иначе клон весит гигабайты, плюс EULA Bohemia.
# Переводы (assets/i18n) наоборот нужны в репозитории: их бандлит сборка.
/assets/tiles/
/assets/buildings/
/assets/__tiles/
/assets/__buildings/
/docs*
/docs/**
