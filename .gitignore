# ---- окружение и кэши ----
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- редакторы и ОС ----
.idea/
*.swp
Thumbs.db
Desktop.ini
.DS_Store

# ---- данные, которые приложение создаёт само ----
# appdata: подложки, датасеты зданий, проекты, снапшоты, crash.log
settings.json
appdata/
DATA_SAMPLE_SERVER/

# ---- артефакты смоук-тестов ----
tools/smoke_*.png

# ---- заметки и документация: держим локально ----
/docs*/

# ---- сборка (pyside6-deploy / Nuitka) ----
/dist/
/src/deployment/
/src/*.build/
/src/*.dist/
/src/*.onefile-build/
/src/app.exe
# ci.spec генерит CI из pysidedeploy.spec: абсолютные пути -> пути раннера
/src/pysidedeploy.ci.spec

# ---- bundled-ассеты ----
# Тайлы подложки и датасеты зданий приложение извлекает из файлов игры само (в appdata/),
# в git их не держим — иначе клон весит гигабайты, плюс EULA Bohemia.
# Переводы (assets/i18n) наоборот НУЖНЫ в репозитории: их бандлит сборка.
/assets/tiles/
/assets/buildings/
/assets/__tiles/
/assets/__buildings/
